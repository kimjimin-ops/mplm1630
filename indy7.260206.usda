#usda 1.0
(
    customLayerData = {
        dictionary cameraSettings = {
            dictionary Front = {
                double3 position = (5, 0.12550200803212835, 0.9136546184738952)
                double radius = 4.067447280883789
            }
            dictionary Perspective = {
                double3 position = (-1.1888336887512032, 3.3401267115275792, 4.774096553470984)
                double3 target = (0.3926601750304064, -0.6405916608337261, 1.5212899225516754)
            }
            dictionary Right = {
                double3 position = (0, -5, 0)
                double radius = 5
            }
            dictionary Top = {
                double3 position = (-0.45533147754308056, 0.7116658514980861, 50001.60927455255)
                double radius = 7.1743110656738285
            }
            string boundCamera = "/OmniverseKit_Persp"
        }
        dictionary metricsAssembler = {
            dictionary "/World/ImageToStl" = {
            }
            dictionary "/World/ImageToStl_01" = {
            }
            dictionary "/World/sample1" = {
            }
            dictionary "/World/workspace_v2" = {
            }
